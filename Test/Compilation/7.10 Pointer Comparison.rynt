public void main() {
    unsafe {
        int x = 5;
        int y = 5;

        ptr<int> p1 = ptr(x);
        ptr<int> p2 = ptr(y);
        ptr<int> p3 = ptr(x);

        bool eq1 = (p1 == p2); // false
        __builtin_print(eq1); __builtin_print("\n");

        bool eq2 = (p1 == p3); // true
        __builtin_print(eq2); __builtin_print("\n");

        bool ne = (p1 != p2); // true
        __builtin_print(ne); __builtin_print("\n");

        ptr<int> p4 = null;
        bool isNull = (p4 == null); // true
        __builtin_print(isNull); __builtin_print("\n");

        bool notNull = (p1 != null); // true
        __builtin_print(notNull); __builtin_print("\n");
    }
}