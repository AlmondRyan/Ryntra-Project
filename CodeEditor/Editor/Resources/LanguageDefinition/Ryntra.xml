<?xml version="1.0" encoding="UTF-8" ?>
<LanguageDefinition xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                    xsi:noNamespaceSchemaLocation="LanguageDef.xsd">
    <Properties>
        <Name>Ryntra</Name>
        <Version>1.0.0</Version>
    </Properties>
    <Contents>
        <Keywords>
            <Keyword>int</Keyword>
            <Keyword>public</Keyword>
            <Keyword>long</Keyword>
            <Keyword>void</Keyword>
            <Keyword>return</Keyword>
            <Keyword>if</Keyword>
            <Keyword>else</Keyword>
            <Keyword>while</Keyword>
            <Keyword>for</Keyword>
            <Keyword>break</Keyword>
            <Keyword>continue</Keyword>
            <Keyword>bool</Keyword>
            <Keyword>true</Keyword>
            <Keyword>false</Keyword>
            <Keyword>null</Keyword>
            <Keyword>new</Keyword>
            <Keyword>ref</Keyword>
            <Keyword>ptr</Keyword>
            <Keyword>unsafe</Keyword>
            <Keyword>fixed</Keyword>
        </Keywords>
        <Match>
            <Number>\d+(?:\.\d+)?[a-zA-Z]*</Number>
            <Comments>
                <Multiline>/\*[\s\S]*?\*/</Multiline>
                <Singleline>//.*</Singleline>
            </Comments>
            <Characters>'[^'\\]*(?:\\.[^'\\]*)*'</Characters>
            <String>"[^"\\]*(?:\\.[^"\\]*)*"</String>
        </Match>
    </Contents>
</LanguageDefinition>